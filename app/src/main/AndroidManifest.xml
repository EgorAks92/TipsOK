<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.skytech.smartskypos" />
        <intent>
            <action android:name="com.skytech.smartskypos.PAYMENT" />
        </intent>
        <package android:name="com.xcheng.wiredecr" />
        <intent>
            <action android:name="com.xcheng.wiredecr.IWireEcrService" />
        </intent>
        <intent>
            <action android:name="com.xcheng.wiredecr.IWireEcrServiceGS" />
        </intent>
    </queries>

    <application
        android:name=".app.ChaiOkApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Tiply"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChaiOK">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ChaiOK.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
